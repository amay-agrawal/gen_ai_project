{
  "name": "ai-outreach-agent",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "express-backend",
    "frontend/*"
  ],
  "scripts": {
    "dev:api": "cd express-backend && npm run dev",
    "dev:dashboard": "cd frontend/dashboard && npm run dev",
    "build:api": "cd express-backend && npm run build",
    "build:dashboard": "cd frontend/dashboard && npm run build",
    "build:extension": "cd frontend/extension && npm run build",
    "build:shared": "cd packages/shared && npm run build",
    "build:all": "npm run build:shared && npm run build:api && npm run build:dashboard",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
